# Production nginx snippet for Parakeet STT: rate limiting + HTTPS.
# Merge the limit_req_zone into your http {} block (once per server).
# Merge the server {} and location /stt/ into your existing server block, or
# include this file from a server block (adjust paths and server_name).

# --- In http {} (e.g. in nginx.conf or a file included at http level): ---
# Rate limit: 10 requests per second per IP for /stt (burst 20).
limit_req_zone $binary_remote_addr zone=stt_limit:10m rate=10r/s;

